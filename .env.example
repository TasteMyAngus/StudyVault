# Root folder for the project on your machine.
# Example: C:\Projects\StudyVault
BASE_DIR=C:\Projects\StudyVault

# Folder where runtime app data is stored.
# Example: C:\Projects\StudyVault\data
DATA_DIR=C:\Projects\StudyVault\data

# Folder that contains the SQLite database file.
# Example: C:\Projects\StudyVault\db
DB_DIR=C:\Projects\StudyVault\db

# Folder where uploaded course files are saved.
# Example: C:\Projects\StudyVault\data\uploads
UPLOADS_DIR=C:\Projects\StudyVault\data\uploads

# Folder reserved for vector store data.
# Example: C:\Projects\StudyVault\data\vector_store
VECTOR_STORE_DIR=C:\Projects\StudyVault\data\vector_store

# Full path to the SQLite database file.
# Example: C:\Projects\StudyVault\db\studyvault.db
DB_PATH=C:\Projects\StudyVault\db\studyvault.db

# OpenAI API Configuration
OPENAI_API_KEY=sk-proj-your-key-here


API_HOST=0.0.0.0
API_PORT=8000
OPENAI_MODEL=gpt-4o
OPENAI_API_URL=https://api.openai.com/v1
OPENAI_TIMEOUT=30
EMBEDDING_MODEL=all-mpnet-base-v2
EMBEDDINGS_DIMENSION=768
RETRIEVAL_TOP_K=8
SIMILARITY_THRESHOLD=0.5
CHUNK_SIZE=300
CHUNK_OVERLAP_PERCENT=0.1
